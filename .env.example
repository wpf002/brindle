# --- core ---
NODE_ENV="development"
PORT="3001"
CORS_ORIGINS="http://localhost:3000"  # Brindle web app origin(s)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/brindle"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-in-prod"

# --- payments (integrated-payment lots: genetics, small lots) ---
STRIPE_SECRET_KEY=""
STRIPE_CONNECT_CLIENT_ID=""
STRIPE_WEBHOOK_SECRET=""
PLATFORM_FEE_BPS="800"     # Brindle platform fee in basis points (800 = 8%)

# --- live video ---
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""

# --- identity / buyer credit ---
PERSONA_API_KEY=""
ADMIN_API_TOKEN=""         # shared secret gating back-office credit approvals

# --- media storage (S3 or Cloudflare R2) ---
S3_BUCKET=""
S3_REGION=""              # "auto" for R2
S3_ENDPOINT=""            # set for R2 (e.g. https://<acct>.r2.cloudflarestorage.com); leave blank for AWS S3
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- market data ---
USDA_AMS_API_KEY=""
